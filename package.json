{
  "name": "breadfruit",
  "version": "3.1.0",
  "description": "Boilerplate SQL query helpers for Node.js using Knex",
  "type": "module",
  "main": "./index.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --test",
    "test:coverage": "c8 --reporter=text --reporter=lcov node --test",
    "prepublishOnly": "npm run lint && npm test"
  },
  "author": "Alyson Zepeda",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/iceddev/breadfruit/issues"
  },
  "homepage": "https://github.com/iceddev/breadfruit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iceddev/breadfruit.git"
  },
  "keywords": [
    "knex",
    "sql",
    "crud",
    "postgres",
    "mysql",
    "database"
  ],
  "dependencies": {
    "knex": "^3.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
